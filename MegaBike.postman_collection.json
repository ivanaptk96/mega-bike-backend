        {
          "name": "Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Current user returned\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Email matches authenticated user\", function () {",
                  "    pm.expect(response.email).to.eql(pm.collectionVariables.get(\"authenticatedEmail\"));",
                  "});",
                  "",
                  "pm.test(\"Authorities are present\", function () {",
                  "    pm.expect(response.authorities).to.be.an(\"array\").and.not.empty;",
                  "});"
                ]
              }
            }
          ],
