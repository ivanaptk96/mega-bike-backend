{
  "info": {
    "_postman_id": "d7a28ee2-9a6b-4b13-a5f5-0c7d6a8f0e5b",
    "name": "Mega Bike Backend",
    "description": "Postman collection for the Mega Bike backend API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login succeeded\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", response.accessToken);",
                  "pm.collectionVariables.set(\"tokenType\", response.tokenType);",
                  "pm.collectionVariables.set(\"authenticatedEmail\", response.email);",
                  "",
                  "pm.test(\"Access token is present\", function () {",
                  "    pm.expect(response.accessToken).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Token type is Bearer\", function () {",
                  "    pm.expect(response.tokenType).to.eql(\"Bearer\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@megabike.local\",\n  \"password\": \"password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates the dev admin user and stores accessToken, tokenType, and authenticatedEmail as collection variables."
          },
          "response": []
        },
