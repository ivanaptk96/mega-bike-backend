        {
          "name": "Login - Invalid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Invalid credentials are rejected\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Error code is INVALID_CREDENTIALS\", function () {",
                  "    pm.expect(response.code).to.eql(\"INVALID_CREDENTIALS\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@megabike.local\",\n  \"password\": \"wrong-password\"\n}",
              "options": {
